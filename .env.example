MCP_HOST=127.0.0.1
MCP_PORT=8787

# Comma-separated bearer tokens. Leave unset only for local demo use.
# MCP_AUTH_TOKEN=replace-with-long-random-token

# Extra allowed browser origins for local testing. chatgpt.com and chat.openai.com are allowed by default.
# CORS_ORIGIN=https://example.com

# ----------------------------------------------------------------------------
# OAuth 2.0 Protected Resource Metadata (RFC 9728) — v0.3.0 foundation
# ----------------------------------------------------------------------------
# The lab serves /.well-known/oauth-protected-resource[/<path>] and emits
# `WWW-Authenticate: Bearer resource_metadata="..."` on 401/403 responses
# (RFC 9728 §5.1). Authorization-server implementation is deferred.
#
# Public resource identifier. Defaults to http://${MCP_HOST}:${MCP_PORT}/mcp.
# Set this when exposing the lab behind a reverse proxy / tunnel.
# MCP_OAUTH_RESOURCE=https://your-public-host.example/mcp

# Comma-separated OAuth authorization server issuer identifiers. Omitted
# from the metadata document when unset. Example:
# MCP_OAUTH_AUTHORIZATION_SERVERS=https://as.example.com,https://as2.example.com

# Comma-separated scopes the resource server is willing to disclose. Omitted
# from the metadata document when unset. Example:
# MCP_OAUTH_SCOPES_SUPPORTED=mcp:read,mcp:tools

# Comma-separated subset of {header, body, query}. Defaults to "header".
# MCP_OAUTH_BEARER_METHODS=header

# Human-readable display name. Defaults to the server name.
# MCP_OAUTH_RESOURCE_NAME=Anotator8 ChatGPT Integration Lab

# URL of resource documentation. Omitted when unset.
# MCP_OAUTH_RESOURCE_DOCUMENTATION=https://your-public-host.example/docs

# Set to "false" to suppress `resource_metadata` from the 401 challenge
# (back-compat with tools that match the legacy header exactly).
# Default: true.
# MCP_OAUTH_CHALLENGE_INCLUDE_METADATA=true
