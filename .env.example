# Anotator8 ChatGPT Integration Lab - Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Server ──────────────────────────────────────────────────────────────────
# Host to bind the MCP server (use 0.0.0.0 for all interfaces in production)
MCP_HOST=127.0.0.1

# Port for the MCP server
MCP_PORT=8787

# ─── Authentication ─────────────────────────────────────────────────────────
# Bearer token for MCP API authentication.
# If set, all /mcp requests must include: Authorization: Bearer <token>
# If not set, authentication is disabled (OK for local development only).
# Generate a secure token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum requests per window per IP
RATE_LIMIT_MAX=100
# Window size in milliseconds (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origin for CORS. Use * for development, specific origin for production.
CORS_ORIGIN=*

# ─── Security ───────────────────────────────────────────────────────────────
# Maximum project data size in bytes (default: 10MB)
# Projects larger than this will be rejected before processing.
# MAX_PROJECT_SIZE=10485760

# ─── Notes ──────────────────────────────────────────────────────────────────
# - Never put API keys, SSH keys, or credentials in this file.
# - Video files are NOT uploaded — only project JSON is sent to ChatGPT.
# - Project data never touches the filesystem from within the server.
