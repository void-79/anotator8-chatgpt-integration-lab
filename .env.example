# Environment variables for Anotator8 ChatGPT Integration Lab

# ── MCP Server ───────────────────────────────────────────
# Host to bind the server to
MCP_HOST=127.0.0.1

# Port to listen on
MCP_PORT=8787

# Bearer token authentication (optional)
# If set, all /mcp requests require: Authorization: Bearer <token>
# Supports multiple tokens separated by commas
# Leave empty to disable authentication (development only)
MCP_AUTH_TOKEN=

# CORS origin (default: *)
CORS_ORIGIN=*

# ── Rate Limiting ────────────────────────────────────────
# Window size in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window (default: 100)
RATE_LIMIT_MAX=100
