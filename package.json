{
  "name": "anotator8-chatgpt-integration-lab",
  "version": "0.4.0",
  "description": "External ChatGPT Apps SDK/MCP integration lab for Anotator8 project review.",
  "private": true,
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build:clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "npm run build:clean && tsc -p tsconfig.build.json",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:fixture": "tsx scripts/gen-near-real-fixture.ts",
    "gen:fixture:check": "tsx scripts/gen-near-real-fixture.ts fixtures/near-real-project.anotator8.json && node -e \"const f=require('./fixtures/near-real-project.anotator8.json');if(!f||!f.nodes||f.nodes.length<10)process.exit(1)\"",
    "demo:oauth": "tsx scripts/oauth-demo.ts",
    "demo:stdio": "tsx scripts/stdio-smoke.ts",
    "pretest": "npm run build",
    "smoke": "tsx scripts/smoke.ts",
    "inspect": "npx -y @modelcontextprotocol/inspector@latest --server-url http://127.0.0.1:8787/mcp --transport http",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.0",
    "@types/node": "^22.19.20",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
